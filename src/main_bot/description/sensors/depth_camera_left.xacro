<?xml version="1.0"?>
<!-- Primary/head depth camera - distinct spec from the 5 body cameras in
     body_cameras.xacro (20Hz, 60deg FOV, 640x480, 0.05-3m range).
     NOTE: references link "depthCamera_link_left", which is not actually
     defined anywhere in go1.xacro (pre-existing from the original Unitree
     template, not introduced by this project's edits). Until that link
     exists, gz sim has nothing to attach this sensor to - not verified
     working yet, unlike imu/foot_contacts/body_cameras. -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Depth camera -->
