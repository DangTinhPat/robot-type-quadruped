  <gazebo reference="depthCamera_link_left">
    <sensor name="camera_link_camera" type="depth">
      <update_rate>20</update_rate>
      <camera>
        <horizontal_fov>1.047198</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>3</far>
        </clip>
      </camera>
      <!-- Gazebo Classic only (libgazebo_ros_openni_kinect.so). The <sensor> itself is
           native to gz sim and renders/publishes on gz transport; bridge to ROS with
           ros_gz_bridge/ros_gz_image if needed. -->
      <!-- <plugin filename="libgazebo_ros_openni_kinect.so" name="camera_link_controller">
